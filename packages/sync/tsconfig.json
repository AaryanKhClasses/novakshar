{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "types": ["node"],
        "moduleResolution": "NodeNext",
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noImplicitOverride": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": [
        "src"
    ]
}
