{
    "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
    "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/shared/**/*", "src/sync/**/*"],
    "compilerOptions": {
        "composite": true,
        "types": ["electron-vite/node"],
        "paths": {
            "@shared/*": ["./src/shared/*"],
            "@main/*": ["./src/main/*"],
            "@preload/*": ["./src/preload/*"],
            "@sync/*": ["./src/sync/*"]
        }
    }
}
