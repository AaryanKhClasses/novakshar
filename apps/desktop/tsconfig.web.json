{
    "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
    "include": [
        "src/renderer/src/env.d.ts",
        "src/renderer/src/**/*",
        "src/renderer/src/**/*.tsx",
        "src/preload/*.d.ts",
        "src/shared/**/*.ts",
        "src/sync/**/*.ts"
    ],
    "compilerOptions": {
        "composite": true,
        "jsx": "react-jsx",
        "paths": {
            "@renderer/*": ["./src/renderer/src/*"],
            "@shared/*": ["./src/shared/*"],
            "@preload/*": ["./src/preload/*"],
            "@sync/*": ["./src/sync/*"]
        }
    }
}
